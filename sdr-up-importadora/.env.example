# ─── Servidor ───────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Provedor de WhatsApp ────────────────────────────────────
# Aceita: "evolution" (Evolution API local) ou "meta" (Meta Cloud API)
WHATSAPP_PROVIDER=evolution

# ─── Evolution API (obrigatório quando WHATSAPP_PROVIDER=evolution) ──
EVOLUTION_URL=http://localhost:8080
EVOLUTION_API_KEY=troque-pela-sua-chave
EVOLUTION_INSTANCE=xiiina-main

# ─── WhatsApp Cloud API / Meta (obrigatório quando WHATSAPP_PROVIDER=meta) ──
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1087505314447476
WHATSAPP_BUSINESS_ACCOUNT_ID=0987654321

# Token de verificação do webhook (você define, use o mesmo na Meta)
WEBHOOK_VERIFY_TOKEN=meutoken123

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Banco de dados (opcional para MVP — deixe vazio para subir sem banco) ──
DATABASE_URL=

# ─── Vendedor (opcional) ─────────────────────────────────────
SELLER_WHATSAPP=5547999999999

# ─── Whitelist de números (opcional) ─────────────────────────
# Números separados por vírgula. Se vazio, todos são processados.
# Em dev, preencha com seus números de teste para evitar respostas indevidas.
ALLOWED_NUMBERS=
